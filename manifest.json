{
  "manifest_version": 3,
  "name": "GMT(Get My Time) 時差轉換擴充插件",
  "version": "3.0.0",
  "description": "選取時間、右鍵轉換、一鍵加日曆 — Right-click to convert time zones. Handles ambiguous TZ, ranges, DST & Google Calendar.",
  "permissions": ["activeTab", "storage", "contextMenus", "scripting"],
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background/background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
